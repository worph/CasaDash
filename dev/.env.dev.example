# CasaDash DEV stack — copy to `.env.dev` and adjust.
# Used by: docker compose --env-file .env.dev -f docker-compose.dev.yml up -d

# Base domain used to build per-app hostnames: <app>-<DOMAIN>, auth-<DOMAIN>, …
# `app.localhost` works out of the box: browsers resolve *.localhost -> 127.0.0.1,
# and dev/certs covers *.localhost. If you change this, also update the `issuer:`
# line in dev/dex/config.yaml and re-run ./gen-certs.sh with matching SANs.
DOMAIN=app.localhost

# Cosmetic locally — feeds store apps' PUBLIC_IP*/nip.io label interpolation.
PUBLIC_IP=127.0.0.1
PUBLIC_IP_DASH=127-0-0-1

# Host location of the data folder, bind-mounted to /DATA (must be an absolute
# host path; apps CasaDash installs bind their volumes under it). On Docker
# Desktop for Windows use a lowercase drive + forward slashes.
DATA_HOST_PATH=d:/workspace/sandbox/CasaDash/DATA

# Timezone for the dashboard and installed apps.
TZ=Europe/Paris

# GID of the host Docker socket's group. `stat -c '%g' /var/run/docker.sock`.
# On Docker Desktop the socket is commonly root-owned → 0.
DOCKER_GID=0

# Seeded operator identity (also the Dex test user's email — informational).
EMAIL=test@casadash.local
DEFAULT_PWD=casadash
