# Copy to `.env` and adjust. Used by docker-compose.yml.

# The data folder ON THE HOST. This same directory is bind-mounted into the
# container at /DATA, and every app CasaDash installs binds its volumes under
# this host path (the host Docker daemon resolves those bind sources). Use an
# absolute host path — e.g. /opt/casadash/DATA, /home/me/casadata, or /DATA.
DATA_HOST_PATH=/DATA

# Timezone applied to the dashboard and installed apps.
TZ=UTC

# Group id of the Docker socket's owning group on the host (usually the
# "docker" group). `stat -c '%g' /var/run/docker.sock` to find it.
DOCKER_GID=999

# Optional: public domain used to build per-app hostnames ({app}.{DOMAIN}).
DOMAIN=
